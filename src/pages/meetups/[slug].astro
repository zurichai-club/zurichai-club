---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const meetups = await getCollection("meetups");
  return meetups.map((meetup) => ({
    params: { slug: meetup.slug },
    props: { meetup }
  }));
}

const { meetup } = Astro.props;
const { Content } = await meetup.render();

const formatDateLong = (date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric"
  }).format(date);

const theme = meetup.data.theme ?? meetup.data.title;

const isSoldOut = meetup.data.status === "sold_out";
const isPast = meetup.data.status === "past";
const rsvpUrl = meetup.data.rsvpUrl;
const currentPath = Astro.url.pathname;
const showRsvp = rsvpUrl && rsvpUrl !== currentPath;
const calendarHref = `${import.meta.env.BASE_URL}calendar/${meetup.slug}.ics`;
---

<BaseLayout title={`${meetup.data.title} | Zurich AI Club`}>
  <article>
    <header class="meetup-hero">
      <div class="meetup-hero__texture"></div>
      <div class="container meetup-hero__content">
        <a class="back-link" href="/"><- Back to home</a>
        <div class="tag-group" style="margin-bottom: 1rem;">
          {meetup.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
          {isSoldOut && <span class="tag tag--sold">SOLD OUT</span>}
        </div>
        <div class="meetup-hero__eyebrow">Zürich AI Meetup presents</div>
        <h1 class="meetup-hero__title">{theme}</h1>
        <div class="meetup-facts" aria-label="Event details">
          <div class="meetup-fact">
            <span class="meetup-fact__label">When</span>
            <span class="meetup-fact__value">
              {formatDateLong(meetup.data.date)} · {meetup.data.time} CEST
            </span>
          </div>
          <div class="meetup-fact">
            <span class="meetup-fact__label">Where</span>
            <span class="meetup-fact__value">{meetup.data.location}</span>
          </div>
        </div>
        <div class="meetup-actions">
          {showRsvp && !isSoldOut && (
            <a class="button button--primary" href={rsvpUrl}>
              RSVP Now
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          )}
          {!isPast && (
            <a class="button button--invert" href={calendarHref} download>
              Add to Calendar
            </a>
          )}
        </div>
      </div>
    </header>

    <div class="meetup-details container">
      {meetup.data.speakers.length > 0 && (
        <section class="lineup-section" aria-labelledby="lineup-title">
          <div class="section-heading">
            <span class="section-heading__kicker">The lineup</span>
            <h2 id="lineup-title">Who is talking about what</h2>
          </div>
          <div class="lineup-grid">
            {meetup.data.speakers.map((speaker) => (
              <article class="lineup-card">
                <img
                  class="lineup-card__photo"
                  src={speaker.photo}
                  alt={`${speaker.name} headshot`}
                  loading="lazy"
                />
                <div class="lineup-card__body">
                  <div class="lineup-card__speaker">
                    <h3>{speaker.name}</h3>
                    {speaker.companyUrl ? (
                      <a href={speaker.companyUrl} target="_blank" rel="noreferrer">
                        {speaker.company}
                      </a>
                    ) : (
                      <span>{speaker.company}</span>
                    )}
                  </div>
                  <p class="lineup-card__label">Talk</p>
                  <p class="lineup-card__title">{speaker.role}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}
      <div class="detail-content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
