---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy | Zurich AI Club" description="Zurich AI Club newsletter privacy information.">
  <section class="meetup-hero">
    <div class="meetup-hero__texture"></div>
    <div class="container meetup-hero__content">
      <a class="back-link" href="/">&lt;- Back to home</a>
      <div class="tag-group" style="margin-bottom: 1rem;">
        <span class="tag">PRIVACY</span>
      </div>
      <h1 class="meetup-hero__title">Newsletter Privacy</h1>
      <div class="detail-content">
        <p>Zurich AI Club uses your email address only to send low-frequency club news and meetup updates.</p>
        <p>By subscribing, you consent to this use. We use Amazon Web Services in the EU (Frankfurt) to store subscription data and deliver emails. Pending confirmations expire after 48 hours.</p>
        <p>Every newsletter includes an unsubscribe link. Unsubscribing removes your email address from our mailing list immediately.</p>
        <p>For questions about your data, contact <a href="mailto:contact@zurichai.club">contact@zurichai.club</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
